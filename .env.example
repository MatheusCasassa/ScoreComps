# ==========================================================================
# Configuração do app OAuth da WCA (cliente público / implicit grant — SEM secret)
# ==========================================================================
# 1. Registre um app em https://www.worldcubeassociation.org/oauth/applications/new
# 2. "Confidential?": deixe DESMARCADO (cliente público, sem secret)
# 3. Redirect URI: a RAIZ do app (com barra no final), uma por linha:
#      dev:  http://localhost:5173/
#      prod: https://sumulas.cubingsp.com.br/
#      (o token volta no fragmento # dessa URL — implicit grant)
# 4. Scopes: marque "public" e "manage_competitions"
# 5. Copie o Client ID (Application UID) e cole abaixo.

# Client ID (UID) do app OAuth da WCA
VITE_WCA_CLIENT_ID=cole-o-application-uid-aqui

# Origem da API/OAuth da WCA
#   Produção:  https://www.worldcubeassociation.org
#   Staging:   https://staging.worldcubeassociation.org
VITE_WCA_ORIGIN=https://www.worldcubeassociation.org

# (Opcional) Base path para deploy em subdiretório (GitHub Pages).
# Deixe em branco para domínio próprio / raiz. Ex.: /sumulas-wca/
# VITE_BASE=/sumulas-wca/
